FROM hashicorp/terraform:1.5.6

RUN apk update && apk add --no-cache \
    curl \
    jq \
    unzip \
    bash \
    less \
    && curl "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o "awscliv2.zip" \
    && unzip awscliv2.zip \
    && ./aws/install \
    && rm -rf awscliv2.zip aws

WORKDIR /workspace

CMD ["/bin/sh"]
